# Ignore everything
**

# Allow all directories (but not their contents)
!*/

# Allow PDF files in any directory
!**/*.pdf
!**/*.tex
!**/*.png
!**/*.jpeg
!**/*.nb
# Ensure the .gitignore file itself is not ignored
!.gitignore

